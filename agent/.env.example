# eBay App ID is already public (same one used client-side in index.html) and
# works with the legacy Finding API without a secret. Override only if you
# create a separate keyset for the agent.
EBAY_APP_ID=

# https://www.pricecharting.com/api-documentation - paid plan required.
# Leave empty to skip grading-arbitrage checks (under-budget checks still run).
PRICECHARTING_API_KEY=

# Cardmarket seller API - not wired up yet, pending seller account approval.
CARDMARKET_APP_TOKEN=
CARDMARKET_APP_SECRET=
CARDMARKET_ACCESS_TOKEN=
CARDMARKET_ACCESS_SECRET=
